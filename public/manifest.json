{
  "manifest_version": 3,
  "name": "Refined YouTube",
  "version": "0.0.0",
  "description": "A refined YouTube experience.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "options.html",
    "default_title": "Refined YouTube"
  },
  "host_permissions": ["*://*.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
