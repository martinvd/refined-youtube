{
  "name": "refined-youtube",
  "version": "1.1.0",
  "private": true,
  "description": "Browser extension that refines the YouTube experience",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch scripts/build.ts",
    "build": "tsc && bun run scripts/build.ts",
    "release": "bun run scripts/release.ts",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/chrome": "^0.1.40",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "~6.0.2"
  }
}
